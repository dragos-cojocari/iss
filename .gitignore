# BORK - Combined .gitignore for Java/Maven and Go

# ============================================
# Go
# ============================================
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories
vendor/

# Go workspace file
go.work
go.work.sum

# ============================================
# Java/Maven
# ============================================
# Compiled class files
*.class

# Log files
*.log

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ============================================
# Environment & Configuration
# ============================================
.env
.env.local
.env.*.local

# Temporary Docker config (workaround for credential helper)
.docker-tmp/

# ============================================
# Editor/IDE
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# IntelliJ IDEA
*.iml
*.ipr
*.iws
.idea/
out/

# Eclipse
.classpath
.project
.settings/

# NetBeans
nbproject/private/
build/
nbbuild/
dist/
nbdist/

# ============================================
# Docker
# ============================================
# Don't ignore docker-compose files, but ignore override
docker-compose.override.yml

# ============================================
# Database
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# OS
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ============================================
# Testing & Development
# ============================================
cookies.txt
*.cookie
